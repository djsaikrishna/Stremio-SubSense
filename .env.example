# SubSense Configuration

# Server port (default: 3100)
PORT=3100

# Public Base URL for the addon (used for subtitle proxy URLs sent to Stremio)
# - For local development: leave commented out (will default to http://127.0.0.1:PORT)
# - For production: set to your public URL (e.g., https://subsense.yourdomain.com)
# SUBSENSE_BASE_URL=https://subsense.yourdomain.com

# Logging level: debug, info, warn, error
LOG_LEVEL=debug

# ============================================
# Provider Configuration
# ============================================

# SUBTITLE_SOURCES: Which providers to enable (comma-separated)
# Available providers: wyzie, betaseries
# - wyzie: Aggregates multiple sources (OpenSubtitles, Subdl, etc.)
# - betaseries: Good for French subtitles (requires BETASERIES_API_KEY)
# Default (if not set): wyzie
SUBTITLE_SOURCES=wyzie,betaseries

# WYZIE_SOURCES: Which sources Wyzie should query (comma-separated)
# Available: OpenSubtitles, Subdl, Subf2m, Podnapisi, AnimeTosho, Gestdown
# If not set, defaults to all available sources
# WYZIE_SOURCES=OpenSubtitles,Subdl,Subf2m,Podnapisi,AnimeTosho,Gestdown

# ============================================
# BetaSeries API (Optional)
# ============================================
# Get your API key at: https://www.betaseries.com/api/
# BETASERIES_API_KEY=your_api_key_here

# ============================================
# Cache Configuration
# ============================================

# Enable/disable caching (default: true)
ENABLE_CACHE=true

# SQLite database file path (default: ./data/subsense.db)
# DB_PATH=./data/subsense.db

# Cache entry retention period in days (default: 30)
# Entries older than this will be automatically cleaned up every 6 hours
CACHE_RETENTION_DAYS=30

# Seconds before triggering background refresh (default: 86400 = 24 hours)
# CACHE_REFRESH_INTERVAL=86400