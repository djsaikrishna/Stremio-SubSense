# SubSense Configuration

# Server port (default: 3100)
PORT=3100

# Public Base URL for the addon (used for subtitle proxy URLs sent to Stremio)
# - For local: leave commented out (will default to http://127.0.0.1:PORT)
# - For production: set to your public URL (e.g., https://subsense.yourdomain.com)
SUBSENSE_BASE_URL=https://subsense.yourdomain.com

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Encryption key for securing provider API keys in manifest URLs
SUBSENSE_ENCRYPTION_KEY=any-secure-passphrase

# ============================================
# Provider Configuration
# ============================================

# SUBTITLE_SOURCES: Which providers to enable (comma-separated)
# Available providers: wyzie, betaseries, yify, tvsubtitles, subsource
# - wyzie: Aggregates multiple sources (OpenSubtitles, Subdl, etc.)
# - betaseries: Good for French subtitles (requires BETASERIES_API_KEY)
# - yify: Movie subtitles from YIFY/YTS
# - tvsubtitles: TV series subtitles from TVsubtitles.net
# - subsource: SubSource provider (requires API key per request)
# Default (if not set): ALL providers are enabled
# SUBTITLE_SOURCES=wyzie,betaseries,yify,tvsubtitles,subsource

# WYZIE_SOURCES: Override which sources Wyzie should query (comma-separated)
# By default, sources are fetched dynamically from the Wyzie API every 24 hours.
# Set this to override with a fixed list (e.g., to exclude certain sources).
# Available: OpenSubtitles, SubDL, Subf2m, Podnapisi, AnimeTosho, Gestdown, Jimaku, Kitsunekko, YIFY
# WYZIE_SOURCES=OpenSubtitles,SubDL,Subf2m,Podnapisi,AnimeTosho,Gestdown,Jimaku,Kitsunekko,YIFY

# REQUIRED for Wyzie to work - API key for Wyzie Subs (free at https://sub.wyzie.io/redeem)
# WYZIE_API_KEY=wyzie-your-key-here

# ============================================
# BetaSeries API (Optional) - French/English provider
# ============================================
# Get your API key at: https://www.betaseries.com/api/
# BETASERIES_API_KEY=your_api_key_here

# ============================================
# Cache Configuration
# ============================================

# Enable/disable caching (default: true)
ENABLE_CACHE=true

# SQLite database file path (default: ./data/subsense.db)
# DB_PATH=./data/subsense.db

# Cache entry retention period in days (default: 14)
CACHE_RETENTION_DAYS=14

# Background refresh interval in SECONDS (default: 604800 = 7 days)
# When cached subtitles are older than this, a background refresh is triggered
CACHE_REFRESH_INTERVAL=604800

# ============================================
# Stats Refresh Configuration
# ============================================

# Stats mode/refresh interval (default: minimal)
# Controls the stats subsystem behavior.
#
# MODES:
# - <not set> or "minimal" = MINIMAL mode (default) — user tracking only, 5min refresh
# - 0                      = DISABLED — no stats, no tracking, zero CPU overhead
# - <number in ms>         = FULL mode — complete stats dashboard refreshed at this interval
#
# Example values for FULL mode:
# - 120000 = 2 minutes
# - 300000 = 5 minutes
# - 1800000 = 30 minutes
# - 3600000 = 1 hour
#
# Recommended: leave unset (minimal) unless you want the full stats dashboard.
# STATS_REFRESH_INTERVAL=minimal
